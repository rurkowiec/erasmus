# KiBlock Docker Configuration
# Copy this file to .env and modify as needed

# Port to run the application on
PORT=9025

# Debug mode (set to False for production)
DEBUG=False

# Allowed hosts (comma-separated, include your domain WITHOUT port)
# Example: ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,192.168.1.100
# Do NOT include ports in ALLOWED_HOSTS
ALLOWED_HOSTS=localhost,127.0.0.1
